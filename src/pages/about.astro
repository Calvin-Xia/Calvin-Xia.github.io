---
import PageIntro from '../components/PageIntro.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { t } from '../lib/i18n.ts';
---

<BaseLayout title={t('about.pageTitle')} titleKey="about.pageTitle" description={t('about.description')} descriptionKey="about.description" currentPage="about">
    <PageIntro
        kicker={t('about.kicker')}
        kickerKey="about.kicker"
        title={t('about.heading')}
        titleKey="about.heading"
        subtitle={t('about.subtitle')}
        subtitleKey="about.subtitle"
    />

    <section class="shadowbox legal-stack">
        <h2 data-i18n="about.copyright">{t('about.copyright')}</h2>
        <p class="indent" data-i18n="about.licenseIntro">{t('about.licenseIntro')}</p>
        <ul class="license-list">
            <li>
                <strong data-i18n="about.sourceCode">{t('about.sourceCode')}</strong>：
                <a href="https://opensource.org/licenses/MIT" target="_blank" rel="noopener">MIT License</a>
                — <span data-i18n="about.sourceTerms">{t('about.sourceTerms')}</span>
            </li>
            <li>
                <strong data-i18n="about.blogArticles">{t('about.blogArticles')}</strong>：
                <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/deed.zh-hans" target="_blank" rel="noopener">CC BY-NC-SA 4.0</a>
                — <span data-i18n="about.blogTerms">{t('about.blogTerms')}</span>
            </li>
        </ul>
        <p class="indent">
            <span data-i18n="about.licenseDetailPrefix">{t('about.licenseDetailPrefix')}</span>
            <a href="https://github.com/Calvin-Xia/Calvin-Xia.github.io/blob/main/LICENSE" target="_blank" rel="noopener">LICENSE</a>
            <span data-i18n="about.licenseDetailSuffix">{t('about.licenseDetailSuffix')}</span>
        </p>

        <h2 data-i18n="about.privacy">{t('about.privacy')}</h2>
        <p class="indent" data-i18n="about.privacyText">{t('about.privacyText')}</p>

        <h2 data-i18n="about.disclaimer">{t('about.disclaimer')}</h2>
        <p class="indent" data-i18n="about.disclaimerText">{t('about.disclaimerText')}</p>

        <h2 data-i18n="about.contact">{t('about.contact')}</h2>
        <p class="indent" data-i18n="about.contactIntro">{t('about.contactIntro')}</p>
        <p class="indent">
            <span data-i18n="about.emailPrefix">{t('about.emailPrefix')}</span><span data-email-placeholder></span><span data-i18n="about.emailSuffix">{t('about.emailSuffix')}</span>
        </p>
    </section>

    <div class="page-return">
        <a
            href="/"
            class="btn btn-secondary"
            data-history="true"
            data-title={t('nav.home')}
            data-i18n-data-title="nav.home"
        >
            ← <span data-i18n="common.backHome">{t('common.backHome')}</span>
        </a>
    </div>
</BaseLayout>

<script>
    import { t } from '../lib/i18n.ts';
    import { EmailProtection } from '../scripts/email-protection';

    function safeInit(moduleName: string, initFn: () => void): void {
        try {
            initFn();
        } catch (error) {
            console.error(`[${t('common.moduleInitError')}] ${moduleName}:`, error);
        }
    }

    function initAboutPage(): void {
        safeInit('EmailProtection', () => EmailProtection.init());
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initAboutPage, { once: true });
    } else {
        initAboutPage();
    }
</script>
