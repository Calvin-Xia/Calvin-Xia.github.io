---
import { getCollection } from 'astro:content';
import PageIntro from '../components/PageIntro.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getUniqueValues } from '../lib/content';
import { t } from '../lib/i18n.ts';

const blogEntries = await getCollection('blog');
const categories = getUniqueValues(blogEntries.map((entry) => entry.data.category));
const today = new Date().toISOString().slice(0, 10);
const isNewPostEnabled = import.meta.env.DEV;
const newPostApiBase = isNewPostEnabled ? 'http://localhost:4322' : '';
const NewPostForm = isNewPostEnabled ? (await import('../components/NewPostForm.astro')).default : null;
---

<BaseLayout title={t('newPost.pageTitle')} titleKey="newPost.pageTitle" description={t('newPost.description')} descriptionKey="newPost.description" currentPage="articles">
    <PageIntro
        kicker={t('newPost.kicker')}
        kickerKey="newPost.kicker"
        title={t('newPost.title')}
        titleKey="newPost.title"
        subtitle={t('newPost.subtitle')}
        subtitleKey="newPost.subtitle"
        compact
    />

    {
        isNewPostEnabled ? (
            <NewPostForm categories={categories} today={today} apiBase={newPostApiBase} />
        ) : (
            <section class="new-post-workbench">
                <div class="card new-post-form">
                    <p class="form-status form-status--pending" role="status">
                        <span data-i18n="newPost.devOnly">{t('newPost.devOnly')}</span>
                    </p>
                </div>
            </section>
        )
    }
</BaseLayout>
