---
import { getCollection, render } from 'astro:content';
import 'katex/dist/katex.min.css';
import ArticleToc from '../../components/ArticleToc.astro';
import GiscusComments from '../../components/GiscusComments.astro';
import LicenseBadge from '../../components/LicenseBadge.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { isFreshDate } from '../../lib/content';
import { t } from '../../lib/i18n.ts';
import { computeReadingStats } from '../../lib/word-count.js';

export async function getStaticPaths() {
    const posts = await getCollection('blog', ({ data }) => data.status !== 'draft');

    return posts.map((post) => ({
        params: { slug: post.id },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const readingStats = computeReadingStats(post.body);
const readTimeDisplay = post.data.readTime || readingStats.readTimeDisplay;
---

<BaseLayout title={`${post.data.title} - Calvin Xia`} description={post.data.excerpt} currentPage="articles">
    <article class="article-detail section-stack">
        <div class="page-return article-return">
            <a
                href="/articles/"
                class="btn btn-secondary"
                data-history="true"
                data-title={t('nav.articles')}
                data-i18n-data-title="nav.articles"
            >
                ← <span data-i18n="common.backArticles">{t('common.backArticles')}</span>
            </a>
        </div>

        <header class="page-intro article-hero">
            <p class="section-kicker">{post.data.category}</p>
            <h1 class="page-title">{post.data.title}</h1>
            <p class="page-subtitle">{post.data.excerpt}</p>
            <div class="blog-card-meta article-meta">
                {isFreshDate(post.data.date) && (
                    <span class="content-type-badge content-type-badge--new" data-i18n="common.new">{t('common.new')}</span>
                )}
                <span class="blog-card-category">{post.data.category}</span>
                {post.data.tags.map((tag) => <span class="blog-card-tag">{tag}</span>)}
                <span class="blog-card-date article-date">{post.data.date}</span>
                <span class="blog-card-date article-date">{readingStats.wordCountDisplay}</span>
                <span class="blog-card-date article-date">{readTimeDisplay}</span>
                <span class="view-count view-count--pending" data-view-counter data-slug={post.id} aria-live="polite" data-i18n="articleDetail.viewsLoading">
                    {t('articleDetail.viewsLoading')}
                </span>
            </div>
        </header>

        <div class="article-reading-layout">
            <section class="markdown-container" aria-label={t('articleDetail.bodyAria')} data-i18n-aria-label="articleDetail.bodyAria">
                <div class="markdown-content">
                    <Content />
                </div>
            </section>
            <ArticleToc />
        </div>
        <GiscusComments />
        <footer class="license-section">
            <LicenseBadge />
        </footer>
    </article>
</BaseLayout>
