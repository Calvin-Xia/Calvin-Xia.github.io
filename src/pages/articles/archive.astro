---
import { getCollection } from 'astro:content';
import PageIntro from '../../components/PageIntro.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { createArchiveGroups } from '../../lib/archive.js';
import { t } from '../../lib/i18n.ts';

const blogEntries = await getCollection('blog', ({ data }) => data.status !== 'draft');
const archiveGroups = createArchiveGroups(blogEntries);
---

<BaseLayout title={t('archive.pageTitle')} description={t('archive.description')} currentPage="articles">
    <PageIntro
        kicker={t('archive.kicker')}
        kickerKey="archive.kicker"
        title={t('archive.title')}
        titleKey="archive.title"
        subtitle={t('archive.subtitle')}
        subtitleKey="archive.subtitle"
        compact
    />

    <section class="archive-timeline" aria-label={t('archive.timelineAria')} data-i18n-aria-label="archive.timelineAria">
        {archiveGroups.map((group) => (
            <section class="archive-year" aria-labelledby={`archive-year-${group.year}`}>
                <h2 id={`archive-year-${group.year}`}>{group.year}</h2>
                <ol class="archive-list">
                    {group.items.map((item) => (
                        <li class="archive-item">
                            <time datetime={item.date}>{item.monthDay}</time>
                            <a href={item.href}>{item.title}</a>
                            <span class="blog-card-category archive-category">{item.category}</span>
                        </li>
                    ))}
                </ol>
            </section>
        ))}
    </section>

    <div class="page-return">
        <a
            href="/articles/"
            class="btn btn-secondary"
            data-history="true"
            data-title={t('nav.articles')}
            data-i18n-data-title="nav.articles"
        >
            ← <span data-i18n="common.backArticles">{t('common.backArticles')}</span>
        </a>
    </div>
</BaseLayout>
