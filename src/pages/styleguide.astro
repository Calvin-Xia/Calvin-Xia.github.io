---
import PageIntro from '../components/PageIntro.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { t } from '../lib/i18n.ts';
---

<BaseLayout title={t('styleguide.pageTitle')} titleKey="styleguide.pageTitle" description={t('styleguide.description')} descriptionKey="styleguide.description">
    <PageIntro
        title={t('styleguide.title')}
        titleKey="styleguide.title"
        subtitle={t('styleguide.subtitle')}
        subtitleKey="styleguide.subtitle"
        compact
    />

    <section class="section-stack">
        <h2 data-i18n="styleguide.colors">{t('styleguide.colors')}</h2>
        <div class="styleguide-grid">
            <div class="token-card token-card--primary">
                <div data-i18n="styleguide.primary">{t('styleguide.primary')}</div>
                <small>#315d67</small>
            </div>
            <div class="token-card token-card--secondary">
                <div data-i18n="styleguide.background">{t('styleguide.background')}</div>
                <small>#f7f7f4</small>
            </div>
            <div class="token-card token-card--accent">
                <div data-i18n="styleguide.border">{t('styleguide.border')}</div>
                <small>#d8dfdd</small>
            </div>
        </div>
    </section>

    <section class="section-stack">
        <h2 data-i18n="styleguide.typography">{t('styleguide.typography')}</h2>
        <div class="card">
            <h1 data-i18n="styleguide.h1">{t('styleguide.h1')}</h1>
            <h2 data-i18n="styleguide.h2">{t('styleguide.h2')}</h2>
            <h3 data-i18n="styleguide.h3">{t('styleguide.h3')}</h3>
            <p data-i18n="styleguide.body">{t('styleguide.body')}</p>
            <p class="text-small" data-i18n="styleguide.small">{t('styleguide.small')}</p>
        </div>
    </section>

    <section class="section-stack">
        <h2 data-i18n="styleguide.buttons">{t('styleguide.buttons')}</h2>
        <div class="card">
            <div class="action-row">
                <button class="btn" data-i18n="styleguide.primaryButton">{t('styleguide.primaryButton')}</button>
                <button class="btn btn-secondary" data-i18n="styleguide.secondaryButton">{t('styleguide.secondaryButton')}</button>
                <button class="btn btn-outline" data-i18n="styleguide.outlineButton">{t('styleguide.outlineButton')}</button>
            </div>
        </div>
    </section>

    <section class="section-stack">
        <h2 data-i18n="styleguide.cards">{t('styleguide.cards')}</h2>
        <div class="card">
            <h3 data-i18n="styleguide.normalCard">{t('styleguide.normalCard')}</h3>
            <p data-i18n="styleguide.normalCardText">{t('styleguide.normalCardText')}</p>
        </div>

        <div class="shadowbox">
            <h3 data-i18n="styleguide.shadowbox">{t('styleguide.shadowbox')}</h3>
            <p data-i18n="styleguide.shadowboxText">{t('styleguide.shadowboxText')}</p>
        </div>
    </section>

    <section class="section-stack">
        <h2 data-i18n="styleguide.time">{t('styleguide.time')}</h2>
        <div class="card">
            <h3 data-i18n="styleguide.timeDisplay">{t('styleguide.timeDisplay')}</h3>
            <div id="currentTime" class="current-time" data-i18n="home.currentTimeLoading">{t('home.currentTimeLoading')}</div>
        </div>
    </section>

    <section class="section-stack">
        <h2 data-i18n="styleguide.links">{t('styleguide.links')}</h2>
        <div class="card">
            <p>
                <span data-i18n="styleguide.linkPrefix">{t('styleguide.linkPrefix')}</span><a href="#" data-i18n="styleguide.standardLink">{t('styleguide.standardLink')}</a><span data-i18n="styleguide.linkSuffix">{t('styleguide.linkSuffix')}</span>
            </p>
        </div>
    </section>

    <section class="section-stack">
        <h2 data-i18n="styleguide.spacing">{t('styleguide.spacing')}</h2>
        <div class="section-stack">
            <div class="card-note">xs - 0.5rem</div>
            <div class="card-note">sm - 1rem</div>
            <div class="card-note">md - 1.5rem</div>
            <div class="card-note">lg - 2rem</div>
            <div class="card-note">xl - 3rem</div>
        </div>
    </section>

    <div class="page-return">
        <a
            href="/"
            class="btn btn-secondary"
            data-history="true"
            data-title={t('nav.home')}
            data-i18n="common.backHome"
            data-i18n-data-title="nav.home"
        >
            {t('common.backHome')}
        </a>
    </div>
</BaseLayout>

<script>
    import { initButtonRipples, PageAnimations } from '../scripts/page-animations';
    import { t } from '../lib/i18n.ts';
    import { TimeDisplay } from '../scripts/time-display';

    function safeInit(moduleName: string, initFn: () => void): void {
        try {
            initFn();
        } catch (error) {
            console.error(`[${t('common.moduleInitError')}] ${moduleName}:`, error);
        }
    }

    function initStyleguidePage(): void {
        safeInit('TimeDisplay', () => TimeDisplay.init());
        safeInit('PageAnimations', () => PageAnimations.init());
        safeInit('ButtonRipples', initButtonRipples);
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initStyleguidePage, { once: true });
    } else {
        initStyleguidePage();
    }
</script>
