---
import PageIntro from '../../components/PageIntro.astro';
import ToolsSection from '../../components/ToolsSection.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../lib/i18n.ts';
---

<BaseLayout title={t('tools.pageTitle')} description={t('tools.description')} currentPage="works">
    <div class="tool-page-main">
        <PageIntro
            kicker={t('tools.kicker')}
            kickerKey="tools.kicker"
            title={t('tools.title')}
            titleKey="tools.title"
            subtitle={t('tools.subtitle')}
            subtitleKey="tools.subtitle"
            center
        />

        <ToolsSection />

        <div class="page-return">
            <a
                href="/works/"
                class="btn btn-secondary"
                data-history="true"
                data-title={t('nav.works')}
                data-i18n="common.backWorks"
                data-i18n-data-title="nav.works"
            >
                {t('common.backWorks')}
            </a>
        </div>
    </div>
</BaseLayout>
