---
import PageIntro from '../../components/PageIntro.astro';
import ToolsSection from '../../components/ToolsSection.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="工具集 - Calvin Xia" description="作品体系下的在线工具集" currentPage="works">
    <div class="tool-page-main">
        <PageIntro
            kicker="作品工具"
            title="工具集"
            subtitle="计时器、随机选择器、Markdown 渲染。"
            center
        />

        <ToolsSection />

        <div class="page-return">
            <a href="/works/" class="btn btn-secondary" data-history="true" data-title="作品">
                返回作品页
            </a>
        </div>
    </div>
</BaseLayout>
