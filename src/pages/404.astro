---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t } from '../lib/i18n.ts';
---

<BaseLayout title="404 - Calvin Xia" description={t('error.description')} descriptionKey="error.description">
    <div class="error-page">
        <div class="error-code">404</div>

        <h1 class="error-title" data-i18n="error.notFound">{t('error.notFound')}</h1>

        <div class="error-panel">
            <p data-i18n="error.message">{t('error.message')}</p>
            <ul class="error-list">
                <li data-i18n="error.wrongUrl">{t('error.wrongUrl')}</li>
                <li data-i18n="error.removed">{t('error.removed')}</li>
            </ul>
        </div>

        <div class="action-row action-row--center page-return">
            <a
                href="/"
                class="btn"
                data-history="true"
                data-title={t('nav.home')}
                data-i18n="error.backHome"
                data-i18n-data-title="nav.home"
            >
                {t('error.backHome')}
            </a>
            <button type="button" onclick="history.back()" class="btn btn-outline" data-i18n="error.backPrevious">
                {t('error.backPrevious')}
            </button>
        </div>

        <p class="text-small">
            <span data-i18n="error.contactPrefix">{t('error.contactPrefix')}</span><a href="mailto:personalpagefeedback@calvin-xia.com" data-i18n="error.contact">{t('error.contact')}</a>
        </p>
    </div>
</BaseLayout>
