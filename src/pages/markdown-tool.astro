---
import MarkdownToolWidget from '../components/MarkdownToolWidget.astro';
import PageIntro from '../components/PageIntro.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { t } from '../lib/i18n.ts';
---

<BaseLayout
    title={t('markdownTool.pageTitle')}
    description={t('markdownTool.description')}
    currentPage="works"
>
    <div class="tool-page-main">
        <PageIntro
            kicker={t('markdownTool.kicker')}
            kickerKey="markdownTool.kicker"
            title={t('markdownTool.title')}
            titleKey="markdownTool.title"
            subtitle={t('markdownTool.subtitle')}
            subtitleKey="markdownTool.subtitle"
            center
        />

        <MarkdownToolWidget />

        <div class="page-return">
            <a
                href="/works/"
                class="btn btn-secondary"
                data-history="true"
                data-title={t('nav.works')}
                data-i18n="common.backWorks"
                data-i18n-data-title="nav.works"
            >
                {t('common.backWorks')}
            </a>
        </div>
    </div>
</BaseLayout>
