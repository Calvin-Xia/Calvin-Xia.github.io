---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
    blogEntryToItem,
    dataEntryToItem,
    getHomepageUpdates,
    isFreshDate,
} from '../lib/content';
import { t } from '../lib/i18n.ts';

const blogEntries = await getCollection('blog', ({ data }) => data.status !== 'draft');
const workEntries = await getCollection('works', ({ data }) => data.status !== 'draft');
const updateEntries = await getCollection('updates', ({ data }) => data.status !== 'draft');
const toolEntries = await getCollection('tools', ({ data }) => data.status !== 'draft');

const homepageUpdates = getHomepageUpdates([
    ...blogEntries.map(blogEntryToItem),
    ...workEntries.map((entry) => dataEntryToItem('work', entry)),
    ...updateEntries.map((entry) => dataEntryToItem('update-log', entry)),
    ...toolEntries.map((entry) => dataEntryToItem('tool', entry)),
]);

const contentTypeKeys = {
    article: 'contentTypes.article',
    work: 'contentTypes.work',
    tool: 'contentTypes.tool',
    'update-log': 'contentTypes.update-log',
};

function contentTypeKey(type, field) {
    return `${contentTypeKeys[type] ?? 'contentTypes.article'}.${field}`;
}
---

<BaseLayout
    title="Calvin Xia"
    description={t('home.description')}
    descriptionKey="home.description"
    currentPage="home"
>
    <section class="hero hero-home page-intro page-intro--center">
        <p class="hero-kicker" data-i18n="home.kicker">{t('home.kicker')}</p>
        <h1 class="page-title hero-title">Calvin Xia</h1>
        <p class="page-subtitle" data-i18n="home.subtitle">{t('home.subtitle')}</p>
        <div class="hero-status">
            <div id="currentTime" class="current-time" data-i18n="home.currentTimeLoading">{t('home.currentTimeLoading')}</div>
        </div>
        <div class="action-row hero-actions">
            <a
                href="/works/"
                class="btn"
                data-history="true"
                data-title={t('nav.works')}
                data-i18n="home.viewWorks"
                data-i18n-data-title="nav.works"
            >
                {t('home.viewWorks')}
            </a>
            <a
                href="/about/"
                class="btn btn-secondary"
                data-history="true"
                data-title={t('nav.about')}
                data-i18n="home.aboutSite"
                data-i18n-data-title="nav.about"
            >
                {t('home.aboutSite')}
            </a>
        </div>
    </section>

    <section class="section-stack home-discovery">
        <h2 class="section-heading" data-i18n="home.discovery">{t('home.discovery')}</h2>
        <div class="list-index home-index-list">
            <a class="index-row" href="/articles/" data-history="true" data-title={t('nav.articles')} data-i18n-data-title="nav.articles">
                <span data-i18n="nav.articles">{t('nav.articles')}</span>
                <strong data-i18n="home.articlesDescription">{t('home.articlesDescription')}</strong>
            </a>
            <a class="index-row" href="/works/" data-history="true" data-title={t('nav.works')} data-i18n-data-title="nav.works">
                <span data-i18n="nav.works">{t('nav.works')}</span>
                <strong data-i18n="home.worksDescription">{t('home.worksDescription')}</strong>
            </a>
            <a class="index-row" href="/about/" data-history="true" data-title={t('nav.about')} data-i18n-data-title="nav.about">
                <span data-i18n="nav.about">{t('nav.about')}</span>
                <strong data-i18n="home.aboutDescription">{t('home.aboutDescription')}</strong>
            </a>
        </div>
    </section>

    <section class="surface-bordered section-stack home-search-panel">
        <div class="home-section-head">
            <div>
                <p class="section-kicker" data-i18n="home.searchKicker">{t('home.searchKicker')}</p>
                <h2 class="section-heading" data-i18n="home.searchTitle">{t('home.searchTitle')}</h2>
            </div>
            <a
                href="/articles/#content-search"
                class="btn btn-outline"
                data-history="true"
                data-title={t('nav.articles')}
                data-i18n="home.openSearch"
                data-i18n-data-title="nav.articles"
            >
                {t('home.openSearch')}
            </a>
        </div>
    </section>

    <section id="recent-updates" class="section-stack home-updates">
        <div class="home-section-head">
            <div>
                <p class="section-kicker" data-i18n="home.recentKicker">{t('home.recentKicker')}</p>
                <h2 class="section-heading" data-i18n="home.recentTitle">{t('home.recentTitle')}</h2>
            </div>
            <a
                href="/articles/#content-search"
                class="btn btn-secondary"
                data-history="true"
                data-title={t('nav.articles')}
                data-i18n="home.viewMore"
                data-i18n-data-title="nav.articles"
            >
                {t('home.viewMore')}
            </a>
        </div>
        <div id="recent-updates-list" class="list-index home-updates-list" aria-live="polite">
            {
                homepageUpdates.map((item) => (
                    <article class="recent-update-card">
                        <div class="recent-update-meta">
                            <span class={`content-type-badge content-type-badge--${item.type}`}>
                                <span data-i18n={contentTypeKey(item.type, 'label')}>
                                    {t(contentTypeKey(item.type, 'label'))}
                                </span>
                            </span>
                            {isFreshDate(item.date) && (
                                <span class="content-type-badge content-type-badge--new" data-i18n="common.new">{t('common.new')}</span>
                            )}
                            <span class="recent-update-date">{item.date}</span>
                        </div>
                        <h3 class="recent-update-title">{item.title}</h3>
                        <a href={item.filePath} class="text-link" data-i18n={contentTypeKey(item.type, 'action')}>
                            {t(contentTypeKey(item.type, 'action'))}
                        </a>
                    </article>
                ))
            }
        </div>
    </section>

    <p class="home-repo-link">
        <a href="https://github.com/Calvin-Xia/mr.xia.github.io" target="_blank" rel="noopener">GitHub Repository</a>
    </p>
</BaseLayout>

<script>
    import { initButtonRipples, PageAnimations } from '../scripts/page-animations';
    import { t } from '../lib/i18n.ts';
    import { TimeDisplay } from '../scripts/time-display';

    function safeInit(moduleName: string, initFn: () => void): void {
        try {
            initFn();
        } catch (error) {
            console.error(`[${t('common.moduleInitError')}] ${moduleName}:`, error);
        }
    }

    const homePageModules = [
        { name: 'TimeDisplay', init: () => TimeDisplay.init() },
        { name: 'PageAnimations', init: () => PageAnimations.init() },
        { name: 'ButtonRipples', init: initButtonRipples },
    ];

    function initHomePage(): void {
        homePageModules.forEach(({ name, init }) => {
            safeInit(name, init);
        });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initHomePage, { once: true });
    } else {
        initHomePage();
    }
</script>
