---
import { t } from '../lib/i18n.ts';
---

<div class="card random-selector-container selector-shell">
    <h3 class="tool-heading" data-i18n="random.heading">{t('random.heading')}</h3>
    <div class="selector-actions selector-actions--editor">
        <input
            type="text"
            id="itemInput"
            class="selector-input"
            placeholder={t('random.placeholder')}
            data-i18n-placeholder="random.placeholder"
            aria-label={t('random.inputAria')}
            data-i18n-aria-label="random.inputAria"
            autocomplete="off"
        />
        <div class="selector-actions selector-actions--compact">
            <button class="btn btn-secondary selector-action-btn" type="button" onclick="RandomSelector.addItem()" data-i18n="random.add">{t('random.add')}</button>
            <button class="btn btn-outline selector-action-btn" type="button" onclick="RandomSelector.deleteAll()" data-i18n="random.clear">{t('random.clear')}</button>
        </div>
    </div>

    <ul id="items" class="selector-list"></ul>

    <div class="selector-actions selector-actions--center">
        <button class="btn" type="button" onclick="RandomSelector.chooseRandom()" data-i18n="random.choose">{t('random.choose')}</button>
    </div>

    <span id="chosen" class="selector-result" aria-live="polite"></span>

    <div id="upload" class="tool-upload">
        <div class="tool-upload-controls">
            <button type="button" class="btn btn-secondary tool-file-trigger" onclick="RandomSelector.openFilePicker()" data-i18n="random.chooseFile">{t('random.chooseFile')}</button>
            <button
                class="btn tool-upload-submit"
                type="button"
                onclick="RandomSelector.handleFiles()"
                aria-label={t('random.uploadAria')}
                data-i18n="random.upload"
                data-i18n-aria-label="random.uploadAria"
            >
                {t('random.upload')}
            </button>
        </div>
        <input
            type="file"
            id="fileInput"
            class="tool-upload-input tool-upload-input--hidden"
            accept=".txt,.md,.docx"
            multiple
            aria-label={t('random.fileInputAria')}
            data-i18n-aria-label="random.fileInputAria"
        />
        <div id="fileSelectionStatus" class="tool-upload-status" aria-live="polite" data-i18n="random.noFile">{t('random.noFile')}</div>
        <div class="tool-note" data-i18n="random.note">{t('random.note')}</div>
    </div>
</div>

<script>
    import '../scripts/random-selector.ts';

    function initRandomSelectorWidget() {
        window.RandomSelector?.init();
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initRandomSelectorWidget, { once: true });
    } else {
        initRandomSelectorWidget();
    }

    document.addEventListener('astro:page-load', initRandomSelectorWidget);
</script>
