---
import OptimizedIcon from './OptimizedIcon.astro';
import { t } from '../lib/i18n.ts';
---

<footer class="site-footer">
    <div class="footer-content">
        {/* i18n source contract: aria-label="站点服务" */}
        <nav class="footer-links" aria-label={t('footer.services')} data-i18n-aria-label="footer.services">
            <a href="/rss.xml" rel="alternate" type="application/rss+xml">RSS</a>
            {import.meta.env.PROD && (
                <>
                    <span aria-hidden="true">·</span>
                    <a href="/sitemap-index.xml">Sitemap</a>
                </>
            )}
            <span aria-hidden="true">·</span>
            <a href="https://cloud.umami.is/share/0cUyNR29irh71HZd" target="_blank" rel="noopener">Umami</a>
        </nav>
        <p class="footer-text">
            <span data-i18n="footer.copyright">{t('footer.copyright')}</span>
            <span aria-hidden="true"> · </span>
            <span data-i18n="footer.poweredBy">{t('footer.poweredBy')}</span>
        </p>
        <p class="footer-text">
            <a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener" data-i18n="footer.icp">
                {t('footer.icp')}
            </a>
            <br />
            <a
                class="record-link"
                href="https://beian.mps.gov.cn/#/query/webSearch?code=50010102001439"
                rel="noreferrer"
                target="_blank"
            >
                <OptimizedIcon
                    class="record-icon"
                    src="/storage/Beian.png"
                    alt={t('footer.recordIconAlt')}
                    width={36}
                    height={40}
                    data-i18n-alt="footer.recordIconAlt"
                />
                <span data-i18n="footer.policeRecord">{t('footer.policeRecord')}</span>
            </a>
        </p>
    </div>
</footer>
