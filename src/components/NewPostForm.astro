---
interface Props {
    categories: string[];
    today: string;
    apiBase: string;
}

import { t } from '../lib/i18n.ts';

const { categories, today, apiBase } = Astro.props;
---

<section class="new-post-workbench">
    <form id="new-post-form" class="card new-post-form" data-api-base={apiBase}>
        <div class="form-grid form-grid--two">
            <label class="form-field">
                <span data-i18n="newPost.titleLabel">{t('newPost.titleLabel')}</span>
                <input id="post-title" name="title" type="text" required />
            </label>
            <label class="form-field">
                <span data-i18n="newPost.dateLabel">{t('newPost.dateLabel')}</span>
                <input id="post-date" name="date" type="date" value={today} required />
            </label>
        </div>

        <div class="form-grid form-grid--two">
            <label class="form-field">
                <span data-i18n="newPost.categoryLabel">{t('newPost.categoryLabel')}</span>
                <select id="post-category" name="category">
                    {categories.map((category) => <option value={category}>{category}</option>)}
                </select>
            </label>
            <label class="form-field">
                <span data-i18n="newPost.tagsLabel">{t('newPost.tagsLabel')}</span>
                <input id="post-tags" name="tags" type="text" placeholder={t('newPost.tagsPlaceholder')} data-i18n-placeholder="newPost.tagsPlaceholder" />
            </label>
        </div>

        <label class="form-field">
            <span data-i18n="newPost.excerptLabel">{t('newPost.excerptLabel')}</span>
            <textarea id="post-excerpt" name="excerpt" rows="3"></textarea>
        </label>

        <label class="form-field">
            <span data-i18n="newPost.secretLabel">{t('newPost.secretLabel')}</span>
            <input id="post-secret" name="secret" type="password" autocomplete="current-password" required />
        </label>

        <div class="editor-container new-post-editor">
            <label class="editor-panel form-field">
                <span class="panel-title" data-i18n="newPost.markdownBody">{t('newPost.markdownBody')}</span>
                <textarea id="post-body" name="body" rows="18"></textarea>
            </label>

            <div class="editor-panel preview-panel">
                <div class="panel-header">
                    <span class="panel-title" data-i18n="newPost.preview">{t('newPost.preview')}</span>
                </div>
                <div class="preview-content">
                    <div id="post-preview" class="markdown-content"></div>
                </div>
            </div>
        </div>

        <div class="action-row new-post-actions">
            <button type="submit" class="btn" data-i18n="newPost.create">{t('newPost.create')}</button>
            <button type="reset" class="btn btn-outline" data-i18n="newPost.clear">{t('newPost.clear')}</button>
        </div>

        <div id="new-post-status" class="form-status" role="status" aria-live="polite"></div>
    </form>
</section>

<script>
    import { t } from '../lib/i18n.ts';

    const form = document.getElementById('new-post-form') as HTMLFormElement | null;
    const titleInput = document.getElementById('post-title') as HTMLInputElement | null;
    const dateInput = document.getElementById('post-date') as HTMLInputElement | null;
    const categoryInput = document.getElementById('post-category') as HTMLSelectElement | null;
    const tagsInput = document.getElementById('post-tags') as HTMLInputElement | null;
    const excerptInput = document.getElementById('post-excerpt') as HTMLTextAreaElement | null;
    const secretInput = document.getElementById('post-secret') as HTMLInputElement | null;
    const bodyInput = document.getElementById('post-body') as HTMLTextAreaElement | null;
    const preview = document.getElementById('post-preview');
    const status = document.getElementById('new-post-status');
    let markdownToolsPromise: Promise<{
        marked: typeof import('marked').marked;
        DOMPurify: typeof import('dompurify').default;
        hljs: typeof import('highlight.js/lib/common').default;
    }> | null = null;

    async function loadMarkdownTools() {
        if (!markdownToolsPromise) {
            markdownToolsPromise = Promise.all([
                import('marked'),
                import('dompurify'),
                import('highlight.js/lib/common'),
            ]).then(([markedModule, dompurifyModule, hljsModule]) => {
                markedModule.marked.use({
                    gfm: true,
                    breaks: true,
                });

                return {
                    marked: markedModule.marked,
                    DOMPurify: dompurifyModule.default,
                    hljs: hljsModule.default,
                };
            });
        }

        return markdownToolsPromise;
    }

    function setStatus(message: string, type = ''): void {
        if (!status) {
            return;
        }

        status.className = `form-status${type ? ` form-status--${type}` : ''}`;
        status.innerHTML = message;
    }

    async function renderPreview(): Promise<void> {
        if (!bodyInput || !preview) {
            return;
        }

        const { marked, DOMPurify, hljs } = await loadMarkdownTools();
        const html = marked.parse(bodyInput.value || '');
        preview.innerHTML = DOMPurify.sanitize(String(html));
        preview.querySelectorAll('pre code').forEach((block) => {
            hljs.highlightElement(block as HTMLElement);
        });
    }

    function getPayload() {
        return {
            title: titleInput?.value.trim() || '',
            date: dateInput?.value.trim() || '',
            category: categoryInput?.value.trim() || '',
            tags: tagsInput?.value.trim() || '',
            excerpt: excerptInput?.value.trim() || '',
            body: bodyInput?.value.trim() || '',
        };
    }

    function validateForm(): boolean {
        if (!titleInput?.value.trim()) {
            titleInput?.focus();
            setStatus(t('newPost.titleRequired'), 'error');
            return false;
        }

        if (!dateInput?.value.trim()) {
            dateInput?.focus();
            setStatus(t('newPost.dateRequired'), 'error');
            return false;
        }

        if (!secretInput?.value.trim()) {
            secretInput?.focus();
            setStatus(t('newPost.secretRequired'), 'error');
            return false;
        }

        return true;
    }

    async function handleSubmit(event: SubmitEvent): Promise<void> {
        event.preventDefault();

        if (!validateForm()) {
            return;
        }

        setStatus(t('newPost.creating'), 'pending');

        try {
            const apiBase = form?.dataset.apiBase || '';
            const response = await fetch(`${apiBase}/api/new-post`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    Authorization: `Bearer ${secretInput?.value.trim() || ''}`,
                },
                body: JSON.stringify(getPayload()),
            });
            const result = await response.json();

            if (!response.ok) {
                const detail = result.errors
                    ? Object.values(result.errors).join('；')
                    : result.error || t('newPost.submitFailed');
                setStatus(detail, 'error');
                return;
            }

            setStatus(
                `${t('newPost.created', { filePath: result.filePath })}<a href="${result.articleUrl}" class="form-status-link">${t('newPost.previewArticle')}</a>`,
                'success',
            );
        } catch (error) {
            const message = error instanceof Error ? error.message : t('newPost.submitFailed');
            setStatus(message, 'error');
        }
    }

    bodyInput?.addEventListener('input', renderPreview);
    form?.addEventListener('submit', handleSubmit);
    form?.addEventListener('reset', () => {
        requestAnimationFrame(() => {
            renderPreview();
            setStatus('');
        });
    });
    renderPreview();
</script>
