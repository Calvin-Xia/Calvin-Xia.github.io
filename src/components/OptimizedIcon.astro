---
interface Props {
    src: string;
    alt: string;
    width?: number;
    height?: number;
    class?: string;
}

const { src, alt, width, height, class: className } = Astro.props;
const webpSrc = src.replace(/\.png$/, '.webp');
---

<picture>
    <source srcset={webpSrc} type="image/webp" />
    <img
        src={src}
        alt={alt}
        width={width}
        height={height}
        class={className}
        loading="lazy"
        decoding="async"
    />
</picture>
