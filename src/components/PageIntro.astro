---
interface Props {
    kicker?: string;
    kickerKey?: string;
    title: string;
    titleKey?: string;
    subtitle?: string;
    subtitleKey?: string;
    center?: boolean;
    compact?: boolean;
}

const {
    kicker,
    kickerKey,
    title,
    titleKey,
    subtitle,
    subtitleKey,
    center = false,
    compact = false,
} = Astro.props;

const classes = [
    'page-intro',
    center ? 'page-intro--center' : '',
    compact ? 'page-intro--compact' : '',
]
    .filter(Boolean)
    .join(' ');
---

<section class={classes}>
    {kicker && <p class="section-kicker" data-i18n={kickerKey}>{kicker}</p>}
    <h1 class="page-title" data-i18n={titleKey}>{title}</h1>
    {subtitle && <p class="page-subtitle" data-i18n={subtitleKey}>{subtitle}</p>}
</section>
