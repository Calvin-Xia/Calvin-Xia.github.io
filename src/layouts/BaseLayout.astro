---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import DynamicBackground from '../components/DynamicBackground.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import SkipLink from '../components/SkipLink.astro';
import TransitionIndicator from '../components/TransitionIndicator.astro';
import { t } from '../lib/i18n.ts';
import localCdnProxyScriptUrl from '../scripts/local-cdn-proxy.js?url';

interface Props {
    title?: string;
    description?: string;
    currentPage?: string;
}

const {
    title = 'Calvin Xia',
    description = t('home.description'),
    currentPage = '',
} = Astro.props;

const enableLocalCdnProxy = import.meta.env.DEV;
---

<!doctype html>
<html lang="zh-CN" data-lang="zh-CN">
    <head>
        <meta charset="UTF-8" />
        <link rel="icon" type="image/webp" href="/storage/icon.webp" />
        <link rel="icon" type="image/png" href="/storage/icon.png" />
        <link rel="manifest" href="/manifest.json" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="referrer" content="strict-origin-when-cross-origin" />
        <link rel="preconnect" href="https://cdnjs.cloudflare.com" />
        <link rel="dns-prefetch" href="https://cdnjs.cloudflare.com" />
        <meta name="description" content={description} />
        <meta name="keywords" content={t('home.keywords')} data-i18n-content="home.keywords" />
        <meta name="author" content="Calvin Xia" />
        <link rel="alternate" type="application/rss+xml" title="Calvin Xia RSS" href="/rss.xml" />
        <title>{title}</title>
        <script is:inline>
            (() => {
                const storageKey = 'calvin-xia-theme';
                let theme = 'light';
                try {
                    theme = localStorage.getItem(storageKey) === 'dark' ? 'dark' : 'light';
                } catch {}
                document.documentElement.dataset.theme = theme;
            })();
        </script>
        <script is:inline>
            (() => {
                const storageKey = 'calvin-xia-lang';
                let lang = 'zh-CN';
                try {
                    lang = localStorage.getItem(storageKey) === 'en-US' ? 'en-US' : 'zh-CN';
                } catch {}
                document.documentElement.lang = lang;
                document.documentElement.dataset.lang = lang;
            })();
        </script>
        <script defer src="https://cloud.umami.is/script.js" data-website-id="d5b9f90c-e82b-4b57-ade7-ff6a3e5d8062" data-host-url="https://cloud.umami.is"></script>
        <ClientRouter fallback="swap" />
    </head>
    <body>
        <SkipLink />
        <DynamicBackground />
        <Header currentPage={currentPage} />
        <main id="main-content" class="site-main" tabindex="-1" transition:name="site-main" transition:animate="fade">
            <slot />
        </main>
        <Footer />
        <TransitionIndicator />
        <script>
            import '../scripts/article-runtime.js';
            import '../scripts/view-counter.js';

            let toolsServiceWorkerRegistrationStarted = false;

            function registerToolsServiceWorker() {
                if (toolsServiceWorkerRegistrationStarted) {
                    return;
                }

                toolsServiceWorkerRegistrationStarted = true;
                navigator.serviceWorker.register('/sw-tools.js', { scope: '/works/tools/' }).catch(() => {
                    toolsServiceWorkerRegistrationStarted = false;
                });
            }

            function scheduleToolsServiceWorkerRegistration() {
                if ('serviceWorker' in navigator && window.location.pathname.startsWith('/works/tools/')) {
                    if (document.readyState === 'complete') {
                        registerToolsServiceWorker();
                    } else {
                        window.addEventListener('load', registerToolsServiceWorker, { once: true });
                    }
                }
            }

            scheduleToolsServiceWorkerRegistration();
            document.addEventListener('astro:page-load', scheduleToolsServiceWorkerRegistration);
        </script>
        {enableLocalCdnProxy && <script type="module" src={localCdnProxyScriptUrl}></script>}
    </body>
</html>
